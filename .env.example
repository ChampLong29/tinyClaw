# LLM Provider Configuration
# Support Anthropic API or compatible providers (e.g. OpenRouter)
ANTHROPIC_API_KEY=sk-ant-xxxxx
MODEL_ID=claude-sonnet-4-20250514

# Optional: custom base URL for API-compatible providers
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# Telegram (optional, for s04_channels.py)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Feishu / Lark (optional, for s04_channels.py)
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_ENCRYPT_KEY=
# FEISHU_BOT_OPEN_ID=
# FEISHU_IS_LARK=false
# FEISHU_MODE=both              # long | webhook | both | off
# FEISHU_WEBHOOK_HOST=0.0.0.0
# FEISHU_WEBHOOK_PORT=8766
# FEISHU_WEBHOOK_PATH=/feishu/events
# FEISHU_REMINDER_TO=oc_xxxxxxxx_or_chat_id   # 可选: 固定接收提醒的飞书会话ID

# Heartbeat (optional, for s07_heartbeat_cron.py)
# HEARTBEAT_INTERVAL=1800
# HEARTBEAT_ACTIVE_START=9
# HEARTBEAT_ACTIVE_END=22
